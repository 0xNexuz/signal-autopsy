# Copy this file to .env.local, then paste your real Bitget credentials there.
# Never commit real API keys to GitHub.

BITGET_API_KEY=replace_with_your_bitget_api_key
BITGET_API_SECRET=replace_with_your_bitget_api_secret
BITGET_API_PASSPHRASE=replace_with_your_bitget_api_passphrase

# Optional later if you add route enforcement from a backend.
BITGET_BASE_URL=https://api.bitget.com
BITGET_TRADING_MODE=paper
